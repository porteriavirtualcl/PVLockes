# Copiar este archivo como ".env" y completar con las credenciales reales.
# NUNCA subir el archivo .env real al repositorio (agregarlo a .gitignore).

# Ruta al archivo JSON de credenciales de servicio de Firebase.
FIREBASE_CREDENTIALS_PATH=./secrets/firebase-service-account.json

# ID del proyecto de Firebase.
FIREBASE_PROJECT_ID=porteria-virtual-xxxxx

# --- Configuración de correo (envío de QR de retiro) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notificaciones@tudominio.cl
SMTP_PASSWORD=cambiar_esta_clave
EMAIL_REMITENTE=notificaciones@tudominio.cl
